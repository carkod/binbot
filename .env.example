# Config files are not tracked in Git and must be placed manually in each
# app environment (e.g. development, staging, production).

# General
PIPENV_VENV_IN_PROJECT=1
PYTHONUNBUFFERED=0
DEBUG=True
TZ="Europe/London"
SECRET_KEY="dev_key"
ENV="development"
FRONTEND_DOMAIN="http://localhost:3000"
BACKEND_DOMAIN="http://localhost:8008"
# 1 year token expiration
ACCESS_TOKEN_EXPIRE_MINUTES="525600"
# Binance keys
BINANCE_KEY=""
BINANCE_SECRET=""

# KuCoin keys
KUCOIN_KEY=""
KUCOIN_SECRET=""
KUCOIN_PASSPHRASE=""

# Telegram API
TELEGRAM_BOT_KEY=""
TELEGRAM_USER_ID=
