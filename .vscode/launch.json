{
  "version": "0.0.2",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Terminal: Vite",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/terminal",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
      "outFiles": [
        "${workspaceFolder}/terminal/**/*.js",
        "${workspaceFolder}/terminal/src/node_modules/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "!**/node_modules/**"
      ],
    },
    {
      "name": "Python: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/api",
      "args": [
        "main:app",
        "--port",
        "8008",
        "--log-level",
        "${env:LOG_LEVEL}"
      ],
      "justMyCode": false,
      "console": "internalConsole",
      "envFile": "${workspaceFolder}/.env",
    },
    {
      "name": "Python: streaming",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/api/market_updates.py",
      "console": "internalConsole",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python: cronjobs",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/api/cronjobs.py",
      "console": "internalConsole",
      "justMyCode": true
    }
  ]
}
